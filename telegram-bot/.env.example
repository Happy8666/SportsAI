# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Football-Data.org API ключ (зарегистрироваться на https://www.football-data.org/)
FOOTBALL_DATA_API_KEY=your_api_key_here

# Режим логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Путь к файлу БД SQLite
DB_PATH=bot_history.db
